# =========================================
# 青禾映画 MVP 环境变量配置模板
# 复制本文件为 .env 并填写实际值
# =========================================

# ---------- LLM 配置 ----------
# 模型名称（支持 OpenAI / DeepSeek / Qwen 等兼容接口）
LLM_MODEL=gpt-4o-mini
# OpenAI 兼容 API 地址
LLM_BASE_URL=https://api.openai.com/v1
# API Key
LLM_API_KEY=sk-xxx
# 采样温度
LLM_TEMPERATURE=0.7
# 最大 token 数
LLM_MAX_TOKENS=2048

# ---------- 应用配置 ----------
APP_HOST=0.0.0.0
APP_PORT=18739
# 日志级别 DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ---------- 前端配置 ----------
STREAMLIT_PORT=18510
# 后端 API 地址（供 Streamlit 调用）
BACKEND_URL=http://localhost:18739

# ---------- 图片生成配置（OpenAI 兼容中转站） ----------
APILINK_API_BASE_URL=https://agaigw.com
AIAPIAL_API_KEY=sk-xxx
IMAGE_MODEL=doubao-seedream-5-0-260128
# seedream 5 要求至少 3686400 像素，1024x1024 会被拒绝
IMAGE_SIZE=1920x1920
IMAGE_RESPONSE_FORMAT=url
