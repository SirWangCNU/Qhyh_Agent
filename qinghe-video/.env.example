# =========================================
# 青禾映画 MVP 环境变量配置模板
# 复制本文件为 .env 并填写实际值
# =========================================

# ---------- LLM 配置 ----------
# 模型名称（支持 OpenAI / DeepSeek / Qwen 等兼容接口）
LLM_MODEL=gpt-4o-mini
# OpenAI 兼容 API 地址
LLM_BASE_URL=https://api.openai.com/v1
# API Key
LLM_API_KEY=sk-xxx
# 采样温度
LLM_TEMPERATURE=0.7
# 最大 token 数
LLM_MAX_TOKENS=2048

# ---------- 应用配置 ----------
APP_HOST=0.0.0.0
APP_PORT=18739
# 日志级别 DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO


# 后端 API 地址（供 Streamlit 调用）
BACKEND_URL=http://localhost:18739

# ---------- 图片生成配置（OpenAI 兼容中转站） ----------
APILINK_API_BASE_URL=https://agaigw.com
AIAPIAL_API_KEY=sk-xxx
IMAGE_MODEL=doubao-seedream-5-0-260128
# seedream 5 要求至少 3686400 像素，1024x1024 会被拒绝
IMAGE_SIZE=1920x1920
IMAGE_RESPONSE_FORMAT=url

# ---------- 鉴权与数据库配置 ----------
# SQLite 数据库文件名（相对项目根目录）
SQLITE_PATH=qinghe.db
# JWT 签名密钥（生产环境务必修改）
JWT_SECRET=qinghe-dev-secret-change-me
# JWT 算法
JWT_ALGORITHM=HS256
# JWT 过期时间（分钟），默认 24 小时
JWT_EXPIRE_MINUTES=1440
# 初始管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
